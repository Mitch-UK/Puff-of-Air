
<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Current Weather Query</title>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-4bw+/aepP/YC94hEpVNVgiZdgIC5+VKNBQNGCHeKRQN+PtmoHDEXuppvnDJzQIu9" crossorigin="anonymous">
        <link rel="stylesheet" href="/css/stylesCurrent.css">
    </head>
    <body style="background-image: url('<%= imagePath %>');">
        <div class="container-current">
            <header class="cardTitle">
                <h1>Weather Forecast</h1>
                <h2 class="dayTime"><%= locals.day %></h2>
            </header >
            <main  class="weather-details">
                <section class="box6"> 
                    <div class="box5">
                        <div class="box7">
                            <img class="box7Img" src="/icons/temp-feels.svg" width="60px"  alt="thermo logo">
                            <span style="text-align: left;"> 
                                <span class="bold">Temp-Feels</span> 
                                <br>
                                <span class="value"> 
                                    <% if (locals.tempFeels) { %>
                                        <%= locals.tempFeels %> °F
                                    <% } else { %>
                                        N/A
                                    <% } %> 
                                </span>
                            </span>
                        </div>
                    </div>
                    <div class="box5"> 
                        <div class="box7">
                            <img class="box7ImgP" src="/icons/pressure.svg" width="40px"  alt="pressure logo">
                            <span style="text-align: left;">
                                <span class="bold">Pressure</span> 
                                <br>
                                <span>               
                                    <% if (locals.pressure) { %>
                                        <%= locals.pressure %> Pa
                                    <% } else { %>
                                        <%='N/A'%>
                                    <% } %>
                                </span>
                            </span> 
                        </div>
                    </div>
                    <div class="box5">
                        <div class="box7">
                            <img class="box7Img" src="/icons/humidity.svg" width="50px" alt="humidity logo">
                            <span style="text-align: left;"><span class="bold">Humidity</span> <br>
                            <span>              
                                <% if (locals.humidity) { %>
                                    <%= locals.humidity %> %
                                <% } else { %>
                                    <%='N/A'%>
                                <% } %>
                            </span>
                        </div>
                    </div>
                    <div class="box5">
                        <div class="box7">
                            <img class="box7Img" src="/icons/wind-speed.svg" width="50px"  alt="wind-speed icon">
                            <span> <span class="bold">W-Speed</span> <br>
                                <span>
                                    <% if (locals.windSpeed) { %>
                                        <%= locals.windSpeed %> m/s
                                    <% } else { %>
                                        <%='N/A'%>
                                    <% } %>
                                </span>
                            </span> 
                        </div>
                    </div>
                    <div class="box5">
                        <div class="box7">
                            <span> Sunrise: </span>
                                <span class="bold">
                                    <% if (locals.formattedSunRise) { %>
                                        <%= locals.formattedSunRise %>
                                    <% } else { %>
                                        <%='N/A'%>
                                    <% } %>
                                </span> 
                                <br>
                            <span class="bold"> Sunset: </span>
                            <span class="bold"> 
                                <% if (locals.formattedSunSet) { %>
                                    <%= locals.formattedSunSet %>
                                <% } else { %>
                                    <%='N/A'%>
                                <% } %>
                            </span>
                        </div>
                    </div>
                    <div class="box5">
                        <div class="box7">
                            <span style="text-align: left;"> Longitude: </span>
                                <span class="bold">
                                    <% if (locals.lon) { %>
                                        <%= locals.lon %>
                                      <% } else { %>
                                        <%='N/A'%>
                                    <% } %>
                                </span> 
                                <br>
                            <span style="text-align: left;"> Latitude: </span> 
                             <span class="bold">
                                <% if (locals.lat) { %>
                                    <%= locals.lat %>
                                  <% } else { %>
                                    <%='N/A'%>
                                  <% } %>
                            </span>
                        </div>
                    </div>
                </section>

                <article  class="card" style="width: 18rem;">
                    <div class="card-body">
                        <h2 class="cardCityName">
                            <% if (locals.cityName) { %>
                                <%= locals.cityName %>
                            <% } else { %>
                                <%='N/A'%>
                            <% } %>
                        </h2>
                        <h3 class="cityTemp">
                            <% if (locals.cityTemp) { %>
                                <%= locals.cityTemp %> °F
                            <% } else { %>
                                <%='N/A'%>
                            <% } %>
                        </h3>
                        <h4>
                            <% if (locals.description) { %>
                                <%= locals.description %>
                            <% } else { %>
                                <%='N/A'%>
                            <% } %>
                        </h4>
                        <% if (locals.weatherIcon) { %>
                            <img class="cardImg" src= <%= weatherIcon %> >
                        <% } else { %>
                            <%='N/A'%>
                        <% } %>
                    </div>
                    <div class="card-body">
                        <h5> Min Temp | Max Temp</h5>
                        <p class="card-minMaxTemp"> 
                            <% if (locals.minTemp && locals.maxTemp) { %>
                                <%= locals.minTemp %> |
                                <%= locals.maxTemp %>
                            <% } else { %>
                                <%='N/A'%>
                            <% } %>
                        </p>
                    </div>
                    <a href="/" class="btn btn-primary">Home</a>
                </article >
            </main >
        </div>
    </body>
</html>
